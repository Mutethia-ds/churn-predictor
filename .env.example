# Copy this file to .env and fill in real values. Never commit .env itself.

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=churn_db
POSTGRES_USER=churn_user
POSTGRES_PASSWORD=change_me

# --- MLflow ---
# Newer MLflow versions deprecate the plain filesystem backend for new
# tracking servers, so we use a local SQLite DB instead (still 100% local,
# no server needed). Artifacts (models, plots) still land in ./mlruns.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Misc ---
ENVIRONMENT=development
RANDOM_SEED=42
